<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>XD Bot — Legal</title>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg: #0d0d14;
      --surface: #13131f;
      --border: #2a2a40;
      --accent: #c8a84b;
      --accent-dim: rgba(200,168,75,0.12);
      --text: #e8e8f0;
      --muted: #7a7a9a;
      --white: #ffffff;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'Inter', sans-serif;
      font-weight: 300;
      line-height: 1.75;
      min-height: 100vh;
    }

    /* top bar */
    header {
      border-bottom: 1px solid var(--border);
      padding: 1.2rem 2rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      position: sticky;
      top: 0;
      background: rgba(13,13,20,0.92);
      backdrop-filter: blur(10px);
      z-index: 10;
    }
    header .logo {
      font-family: 'Cinzel', serif;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.08em;
    }
    header .sep { color: var(--border); }
    header nav { display: flex; gap: 1.5rem; margin-left: auto; }
    header nav a {
      color: var(--muted);
      text-decoration: none;
      font-size: 0.85rem;
      letter-spacing: 0.04em;
      transition: color 0.2s;
    }
    header nav a:hover { color: var(--accent); }

    /* tabs */
    .tabs {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      max-width: 780px;
      margin: 2.5rem auto 0;
      padding: 0 2rem;
    }
    .tab {
      font-family: 'Cinzel', serif;
      font-size: 0.8rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      padding: 0.75rem 1.5rem;
      cursor: pointer;
      color: var(--muted);
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      user-select: none;
    }
    .tab.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }
    .tab:hover:not(.active) { color: var(--text); }

    /* content */
    main {
      max-width: 780px;
      margin: 0 auto;
      padding: 3rem 2rem 6rem;
    }

    .page { display: none; }
    .page.active { display: block; }

    .page-header {
      margin-bottom: 2.5rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--border);
    }
    .page-header .eyebrow {
      font-family: 'Cinzel', serif;
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.5rem;
    }
    .page-header h1 {
      font-family: 'Cinzel', serif;
      font-size: 1.8rem;
      font-weight: 700;
      color: var(--white);
      margin-bottom: 0.5rem;
    }
    .page-header .meta {
      font-size: 0.8rem;
      color: var(--muted);
    }

    section {
      margin-bottom: 2.5rem;
    }
    section h2 {
      font-family: 'Cinzel', serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    section h2::before {
      content: '';
      display: inline-block;
      width: 3px;
      height: 0.9rem;
      background: var(--accent);
      border-radius: 2px;
    }
    section p {
      font-size: 0.9rem;
      color: var(--text);
      margin-bottom: 0.6rem;
    }
    section ul {
      list-style: none;
      padding: 0;
    }
    section ul li {
      font-size: 0.9rem;
      color: var(--text);
      padding: 0.3rem 0 0.3rem 1.2rem;
      position: relative;
    }
    section ul li::before {
      content: '◆';
      position: absolute;
      left: 0;
      font-size: 0.45rem;
      color: var(--accent);
      top: 0.55rem;
    }

    .callout {
      background: var(--accent-dim);
      border: 1px solid rgba(200,168,75,0.25);
      border-left: 3px solid var(--accent);
      border-radius: 4px;
      padding: 1rem 1.2rem;
      font-size: 0.88rem;
      color: var(--text);
      margin: 1.5rem 0;
    }
    .callout a {
      color: var(--accent);
      text-decoration: none;
    }
    .callout a:hover { text-decoration: underline; }

    footer {
      text-align: center;
      padding: 2rem;
      border-top: 1px solid var(--border);
      font-size: 0.78rem;
      color: var(--muted);
    }
    footer a { color: var(--accent); text-decoration: none; }
  </style>
</head>
<body>

<header>
  <span class="logo">✦ XD Bot</span>
  <span class="sep">|</span>
  <span style="font-size:0.82rem;color:var(--muted);">Legal Documents</span>
  <nav>
    <a href="https://discord.gg/Gz3dEH9VpJ" target="_blank">Support Server</a>
    <a href="https://top.gg/bot/1305780094937337906/vote" target="_blank">Vote</a>
  </nav>
</header>

<div class="tabs">
  <div class="tab active" onclick="switchTab('tos')">Terms of Service</div>
  <div class="tab" onclick="switchTab('privacy')">Privacy Policy</div>
</div>

<main>

